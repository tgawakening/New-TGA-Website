# Copy this file to .env.local (or .env) and fill in real values.
# Do not commit real secrets.

# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL="mysql://root:password@localhost:3306/global_awakening"

# Production / Vercel example:
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
# DATABASE_URL="mysql://doadmin:password@db-host:25060/defaultdb?sslcert=./certs/ca-certificate.crt&sslaccept=strict"
ADMIN_API_TOKEN="replace_with_long_random_admin_token"
ADMIN_DASHBOARD_EMAIL="admin@example.com"
ADMIN_DASHBOARD_PASSWORD="replace_with_admin_password"
ADMIN_DASHBOARD_SECRET="replace_with_long_random_admin_session_secret"

# Stripe
# Optional for future client-side Stripe usage:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_or_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# PayPal
PAYPAL_ENV="sandbox" # sandbox or live
PAYPAL_CLIENT_ID="paypal_client_id"
PAYPAL_CLIENT_SECRET="paypal_client_secret"

# Email
RESEND_API_KEY="re_xxx"
# Must be a sender on a verified domain in Resend, not a plain Gmail address.
EMAIL_FROM="Global Awakening <noreply@your-domain.com>"
ADMIN_NOTIFICATION_EMAIL="tgawakening786@gmail.com"

# Example:
# API_BASE_URL=https://api.example.com
# API_KEY=replace_me
